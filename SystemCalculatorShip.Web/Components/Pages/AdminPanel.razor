@page "/admin"
@inject NavigationManager Navigation
@inject ServiceClient ApiClient
@inject IJSRuntime JSRuntime

<div class="container-fluid mt-4">
    @if (!isReady)
    {
        <div class="alert alert-info">Loading admin panel...</div>
    }
    else
    {
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>📊 Admin Panel</h1>
        <button class="btn btn-outline-danger" @onclick="Logout">
            Logout
        </button>
    </div>

    <div class="row">
        <div class="col-12">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "countries" ? "active" : "")" 
                            @onclick='() => SetActiveTab("countries")' role="tab">
                        🌍 Countries
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "tariffs" ? "active" : "")" 
                            @onclick='() => SetActiveTab("tariffs")' role="tab">
                        💰 Tariffs
                    </button>
                </li>
            </ul>

            <div class="tab-content mt-4">
                @if (activeTab == "countries")
                {
                    <Countries ApiClient="@ApiClient" />
                }
                else if (activeTab == "tariffs")
                {
                    <Tariffs ApiClient="@ApiClient" />
                }
            </div>
        </div>
    </div>
    }
</div>

@code {
    private string activeTab = "countries";
    private bool isReady;
    private bool firstRenderCompleted;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || firstRenderCompleted)
        {
            return;
        }

        firstRenderCompleted = true;

        await ApiClient.LoadTokenAsync();

        var storedTab = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "admin_active_tab");
        if (!string.IsNullOrWhiteSpace(storedTab))
        {
            activeTab = storedTab;
        }

        if (!await ApiClient.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/login");
            return;
        }

        isReady = true;
        StateHasChanged();
    }

    private async Task SetActiveTab(string tab)
    {
        activeTab = tab;
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "admin_active_tab", tab);
    }

    private async Task Logout()
    {
        await ApiClient.ClearTokenAsync();
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "admin_active_tab");
        Navigation.NavigateTo("/", forceLoad: true);
    }
}
