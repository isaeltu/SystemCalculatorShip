@page "/calculator"
@using System.Globalization
@inject ServiceClient ApiClient

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="card shadow-lg">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">📦 Shipping Cost Calculator</h4>
                </div>
                <div class="card-body">
                    <EditForm Model="calculateRequest" OnValidSubmit="Calculate" FormName="calculator-form">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="alert alert-danger" />

                        <div class="mb-3">
                            <label class="form-label">Destination Country</label>
                            <InputSelect @bind-Value="calculateRequest.CountryCode" @bind-Value:after="LoadTariffsForSelectedCountry" class="form-select">
                                <option value="">-- Select a country --</option>
                                @foreach (var country in countries)
                                {
                                    <option value="@country.Code">@country.Name (@country.Code)</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => calculateRequest.CountryCode" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Weight (kg)</label>
                            <InputNumber @bind-Value="calculateRequest.Weight" class="form-control" placeholder="Enter weight in kilograms" />
                            <ValidationMessage For="() => calculateRequest.Weight" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Tariff Type</label>
                            <InputSelect @bind-Value="calculateRequest.TariffType" class="form-select">
                                <option value="">-- Select tariff type --</option>
                                @foreach (var tariff in tariffs)
                                {
                                    <option value="@tariff.Type">@FormatTariffLabel(tariff)</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => calculateRequest.TariffType" />
                        </div>

                        @if (tariffs.Count > 0)
                        {
                            <div class="alert alert-info mb-3">
                                <strong>Tariffs for @selectedCountryName:</strong>
                                <ul class="mb-0 mt-2">
                                    @foreach (var tariff in tariffs)
                                    {
                                        <li>@FormatTariffLabel(tariff)</li>
                                    }
                                </ul>
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(calculateRequest.CountryCode))
                        {
                            <div class="alert alert-warning mb-3">
                                No tariffs were found for the selected country.
                            </div>
                        }

                        <button type="submit" class="btn btn-primary w-100" disabled="@isCalculating">
                            @if (isCalculating)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Calculating...</span>
                            }
                            else
                            {
                                <span>Calculate Cost</span>
                            }
                        </button>
                    </EditForm>

                    @if (result != null)
                    {
                        <div class="alert alert-success mt-4">
                            <h5 class="alert-heading">✅ Shipping Cost Calculated</h5>
                            <hr />
                            <div class="row">
                                <div class="col-md-6">
                                    <p><strong>Country:</strong> @result.Country</p>
                                    <p><strong>Tariff Type:</strong> @result.TariffType</p>
                                </div>
                                <div class="col-md-6">
                                    <p><strong>Weight:</strong> @result.Weight kg</p>
                                    <p><strong>Rate:</strong> $@result.RatePerKg / kg</p>
                                </div>
                            </div>
                            <hr />
                            <h4 class="text-success">Total Cost: $@result.TotalCost.ToString("F2")</h4>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mt-4">
                            ❌ Error: @errorMessage
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private CalculateShippingRequest calculateRequest = new();
    private CalculateShippingResponse? result;
    private List<CountryDto> countries = new();
    private List<TariffDto> tariffs = new();
    private string selectedCountryName = string.Empty;
    private string errorMessage = string.Empty;
    private bool isCalculating = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadCountries();
    }

    private async Task LoadCountries()
    {
        try
        {
            var response = await ApiClient.GetAsync<ApiResponse<IEnumerable<CountryDto>>>("/api/countries");
            if (response?.Success == true && response.Data != null)
            {
                countries = response.Data.ToList();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading countries: {ex.Message}";
        }
    }

    private async Task LoadTariffsForSelectedCountry()
    {
        tariffs = new List<TariffDto>();
        selectedCountryName = string.Empty;
        calculateRequest.TariffType = string.Empty;
        result = null;

        if (string.IsNullOrWhiteSpace(calculateRequest.CountryCode))
        {
            return;
        }

        var selectedCountry = countries.FirstOrDefault(c => c.Code.Equals(calculateRequest.CountryCode, StringComparison.OrdinalIgnoreCase));
        selectedCountryName = selectedCountry?.Name ?? calculateRequest.CountryCode;

        try
        {
            var response = await ApiClient.GetAsync<ApiResponse<IEnumerable<TariffDto>>>(
                $"/api/tariffs/country/{calculateRequest.CountryCode}");

            if (response?.Success == true && response.Data != null)
            {
                tariffs = response.Data.ToList();
            }
            else
            {
                errorMessage = response?.Message ?? "No tariffs available for this country.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading tariffs: {ex.Message}";
        }
    }

    private static string FormatTariffLabel(TariffDto tariff)
    {
        return $"{CultureInfo.InvariantCulture.TextInfo.ToTitleCase(tariff.Type)} - {tariff.Currency} {tariff.RatePerKg:F2}/kg";
    }

    private async Task Calculate()
    {
        errorMessage = string.Empty;
        result = null;
        isCalculating = true;

        try
        {
            var response = await ApiClient.PostAsync<CalculateShippingRequest, ApiResponse<CalculateShippingResponse>>(
                "/api/shipping/calculate", calculateRequest);

            if (response?.Success == true && response.Data != null)
            {
                result = response.Data;
            }
            else
            {
                errorMessage = response?.Message ?? "Failed to calculate shipping cost.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isCalculating = false;
        }
    }
}
