@namespace SystemCalculatorShip.Web.Components.Pages.Admin

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">Tariffs Management</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <button class="btn btn-success mb-3" @onclick="() => showCreateForm = !showCreateForm">
            @if (showCreateForm) { <span>✕ Cancel</span> } else { <span>+ Add Tariff</span> }
        </button>

        @if (showCreateForm)
        {
            <div class="card bg-light mb-3">
                <div class="card-body">
                    <h6 class="card-title">New Tariff</h6>
                    <EditForm Model="newTariff" OnValidSubmit="CreateTariff" FormName="tariffs-form">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="alert alert-danger" />

                        <div class="row">
                            <div class="col-md-3">
                                <label class="form-label">Country</label>
                                <InputSelect @bind-Value="newTariff.CountryId" class="form-select">
                                    <option value="0">-- Select --</option>
                                    @foreach (var country in countries)
                                    {
                                        <option value="@country.Id">@country.Name</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="() => newTariff.CountryId" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Type</label>
                                <InputSelect @bind-Value="newTariff.Type" class="form-select">
                                    <option value="">-- Select --</option>
                                    <option value="standard">Standard</option>
                                    <option value="express">Express</option>
                                    <option value="economy">Economy</option>
                                    <option value="premium">Premium</option>
                                </InputSelect>
                                <ValidationMessage For="() => newTariff.Type" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Rate/Kg ($)</label>
                                <InputNumber @bind-Value="newTariff.RatePerKg" class="form-control" placeholder="0.00" />
                                <ValidationMessage For="() => newTariff.RatePerKg" />
                            </div>
                            <div class="col-md-3 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary w-100">Add</button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        }

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Country</th>
                        <th>Type</th>
                        <th>Rate/Kg</th>
                        <th>Currency</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (tariffs.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">No tariffs found</td>
                        </tr>
                    }
                    @foreach (var tariff in tariffs)
                    {
                        <tr>
                            <td>@tariff.CountryName</td>
                            <td>
                                @if (editingTariffId == tariff.Id)
                                {
                                    <InputSelect @bind-Value="editTariffType" class="form-select form-select-sm">
                                        <option value="standard">Standard</option>
                                        <option value="express">Express</option>
                                        <option value="economy">Economy</option>
                                        <option value="premium">Premium</option>
                                    </InputSelect>
                                }
                                else
                                {
                                    <span class="badge bg-info">@tariff.Type</span>
                                }
                            </td>
                            <td>
                                @if (editingTariffId == tariff.Id)
                                {
                                    <InputNumber @bind-Value="editTariffRatePerKg" class="form-control form-control-sm" />
                                }
                                else
                                {
                                    @tariff.RatePerKg.ToString("F2")
                                }
                            </td>
                            <td>@tariff.Currency</td>
                            <td>
                                @if (editingTariffId == tariff.Id)
                                {
                                    <button class="btn btn-sm btn-primary me-1" @onclick="SaveTariffEdit">Save</button>
                                    <button class="btn btn-sm btn-secondary" @onclick="CancelTariffEdit">Cancel</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-warning me-1" @onclick="() => EditTariff(tariff)">Edit</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteTariff(tariff.Id)">Delete</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public ServiceClient? ApiClient { get; set; }

    private List<TariffDto> tariffs = new();
    private List<CountryDto> countries = new();
    private CreateTariffRequest newTariff = new();
    private bool showCreateForm = false;
    private int? editingTariffId;
    private string editTariffType = "standard";
    private decimal? editTariffRatePerKg;
    private string successMessage = string.Empty;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadCountries();
        await LoadTariffs();
    }

    private async Task LoadCountries()
    {
        try
        {
            if (ApiClient != null)
            {
                var response = await ApiClient.GetAsync<ApiResponse<IEnumerable<CountryDto>>>("/api/countries");
                if (response?.Success == true && response.Data != null)
                {
                    countries = response.Data.ToList();
                    errorMessage = string.Empty;
                }
                else
                {
                    errorMessage = response?.Message ?? "No se pudieron cargar los paises.";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading countries: {ex.Message}";
        }
    }

    private async Task LoadTariffs()
    {
        try
        {
            if (ApiClient != null)
            {
                var response = await ApiClient.GetAsync<ApiResponse<IEnumerable<TariffDto>>>("/api/tariffs");
                if (response?.Success == true && response.Data != null)
                {
                    tariffs = response.Data.ToList();
                    errorMessage = string.Empty;
                }
                else
                {
                    errorMessage = response?.Message ?? "No se pudieron cargar las tarifas. Verifica que el login este activo.";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading tariffs: {ex.Message}";
        }
    }

    private async Task CreateTariff()
    {
        try
        {
            if (ApiClient != null && newTariff.CountryId > 0 && !string.IsNullOrEmpty(newTariff.Type))
            {
                var response = await ApiClient.PostAsync<CreateTariffRequest, ApiResponse<TariffDto>>(
                    "/api/tariffs", newTariff);

                if (response?.Success == true)
                {
                    newTariff = new();
                    showCreateForm = false;
                    successMessage = "Tarifa creada correctamente.";
                    errorMessage = string.Empty;
                    await LoadTariffs();
                }
                else
                {
                    errorMessage = response?.Message ?? "No se pudo crear la tarifa.";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error creating tariff: {ex.Message}";
        }
    }

    private Task EditTariff(TariffDto tariff)
    {
        editingTariffId = tariff.Id;
        editTariffType = tariff.Type;
        editTariffRatePerKg = tariff.RatePerKg;
        successMessage = string.Empty;
        errorMessage = string.Empty;
        return Task.CompletedTask;
    }

    private async Task SaveTariffEdit()
    {
        try
        {
            if (ApiClient == null || editingTariffId == null || !editTariffRatePerKg.HasValue)
                return;

            var request = new UpdateTariffRequest
            {
                Type = editTariffType,
                RatePerKg = editTariffRatePerKg.Value
            };

            var response = await ApiClient.PutAsync<UpdateTariffRequest, ApiResponse<TariffDto>>(
                $"/api/tariffs/{editingTariffId.Value}", request);

            if (response?.Success == true)
            {
                successMessage = "Tarifa actualizada correctamente.";
                errorMessage = string.Empty;
                editingTariffId = null;
                await LoadTariffs();
            }
            else
            {
                errorMessage = response?.Message ?? "No se pudo actualizar la tarifa.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating tariff: {ex.Message}";
        }
    }

    private Task CancelTariffEdit()
    {
        editingTariffId = null;
        editTariffType = "standard";
        editTariffRatePerKg = null;
        return Task.CompletedTask;
    }

    private async Task DeleteTariff(int id)
    {
        try
        {
            if (ApiClient != null)
            {
                var response = await ApiClient.DeleteAsync<ApiResponse<string>>($"/api/tariffs/{id}");
                if (response?.Success == true)
                {
                    successMessage = "Tarifa eliminada correctamente.";
                    errorMessage = string.Empty;
                    await LoadTariffs();
                }
                else
                {
                    errorMessage = response?.Message ?? "No se pudo eliminar la tarifa.";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting tariff: {ex.Message}";
        }
    }
}
