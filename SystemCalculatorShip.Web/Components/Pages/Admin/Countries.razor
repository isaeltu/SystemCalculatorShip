@namespace SystemCalculatorShip.Web.Components.Pages.Admin

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">Countries Management</h5>
    </div>
    <div class="card-body">
        <button class="btn btn-success mb-3" @onclick="() => showCreateForm = !showCreateForm">
            @if (showCreateForm) { <span>✕ Cancel</span> } else { <span>+ Add Country</span> }
        </button>

        @if (showCreateForm)
        {
            <div class="card bg-light mb-3">
                <div class="card-body">
                    <h6 class="card-title">New Country</h6>
                    <EditForm Model="newCountry" OnValidSubmit="CreateCountry">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="alert alert-danger" />

                        <div class="row">
                            <div class="col-md-3">
                                <label class="form-label">Country Code (2 chars)</label>
                                <InputText @bind-Value="newCountry.Code" class="form-control" placeholder="e.g., IN" />
                                <ValidationMessage For="() => newCountry.Code" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Country Name</label>
                                <InputText @bind-Value="newCountry.Name" class="form-control" placeholder="e.g., India" />
                                <ValidationMessage For="() => newCountry.Name" />
                            </div>
                            <div class="col-md-3 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary w-100">Add</button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        }

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (countries.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted">No countries found</td>
                        </tr>
                    }
                    @foreach (var country in countries)
                    {
                        <tr>
                            <td><strong>@country.Code</strong></td>
                            <td>@country.Name</td>
                            <td>N/A</td>
                            <td>
                                <button class="btn btn-sm btn-warning" @onclick="() => EditCountry(country.Id)">Edit</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteCountry(country.Id)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public ServiceClient? ApiClient { get; set; }

    private List<CountryDto> countries = new();
    private CreateCountryRequest newCountry = new();
    private bool showCreateForm = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadCountries();
    }

    private async Task LoadCountries()
    {
        try
        {
            if (ApiClient != null)
            {
                var response = await ApiClient.GetAsync<ApiResponse<IEnumerable<CountryDto>>>("/api/countries");
                if (response?.Success == true && response.Data != null)
                {
                    countries = response.Data.ToList();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading countries: {ex.Message}");
        }
    }

    private async Task CreateCountry()
    {
        try
        {
            if (ApiClient != null)
            {
                var response = await ApiClient.PostAsync<CreateCountryRequest, ApiResponse<CountryDto>>(
                    "/api/countries", newCountry);

                if (response?.Success == true)
                {
                    newCountry = new();
                    showCreateForm = false;
                    await LoadCountries();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating country: {ex.Message}");
        }
    }

    private async Task EditCountry(int id)
    {
        // TODO: Implement edit functionality
    }

    private async Task DeleteCountry(int id)
    {
        try
        {
            if (ApiClient != null)
            {
                await ApiClient.DeleteAsync($"/api/countries/{id}");
                await LoadCountries();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting country: {ex.Message}");
        }
    }
}
