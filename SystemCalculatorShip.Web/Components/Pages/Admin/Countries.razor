@namespace SystemCalculatorShip.Web.Components.Pages.Admin

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">Countries Management</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <button type="button" class="btn btn-success mb-3" @onclick="() => showCreateForm = !showCreateForm">
            @if (showCreateForm) { <span>✕ Cancel</span> } else { <span>+ Add Country</span> }
        </button>

        @if (showCreateForm)
        {
            <div class="card bg-light mb-3">
                <div class="card-body">
                    <h6 class="card-title">New Country</h6>
                    <EditForm Model="newCountry" OnValidSubmit="CreateCountry" FormName="countries-form">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="alert alert-danger" />

                        <div class="row">
                            <div class="col-md-3">
                                <label class="form-label">Country Code (2 chars)</label>
                                <InputText @bind-Value="newCountry.Code" class="form-control" placeholder="e.g., IN" />
                                <ValidationMessage For="() => newCountry.Code" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Country Name</label>
                                <InputText @bind-Value="newCountry.Name" class="form-control" placeholder="e.g., India" />
                                <ValidationMessage For="() => newCountry.Name" />
                            </div>
                            <div class="col-md-3 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary w-100">Add</button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        }

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (countries.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted">No countries found</td>
                        </tr>
                    }
                    @foreach (var country in countries)
                    {
                        <tr>
                            <td><strong>@country.Code</strong></td>
                            <td>
                                @if (editingCountryId == country.Id)
                                {
                                    <InputText @bind-Value="editCountryName" class="form-control form-control-sm" />
                                }
                                else
                                {
                                    @country.Name
                                }
                            </td>
                            <td>N/A</td>
                            <td>
                                @if (editingCountryId == country.Id)
                                {
                                    <button type="button" class="btn btn-sm btn-primary me-1" @onclick="SaveCountryEdit">Save</button>
                                    <button type="button" class="btn btn-sm btn-secondary" @onclick="CancelCountryEdit">Cancel</button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-warning me-1" @onclick="() => EditCountry(country)">Edit</button>
                                    <button type="button" class="btn btn-sm btn-danger" @onclick="() => DeleteCountry(country.Id)">Delete</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public ServiceClient? ApiClient { get; set; }

    private List<CountryDto> countries = new();
    private CreateCountryRequest newCountry = new();
    private bool showCreateForm = false;
    private int? editingCountryId;
    private string editCountryName = string.Empty;
    private string successMessage = string.Empty;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadCountries();
    }

    private async Task LoadCountries()
    {
        try
        {
            if (ApiClient != null)
            {
                var response = await ApiClient.GetAsync<ApiResponse<IEnumerable<CountryDto>>>("/api/countries");
                if (response?.Success == true && response.Data != null)
                {
                    countries = response.Data.ToList();
                    errorMessage = string.Empty;
                }
                else
                {
                    errorMessage = response?.Message ?? "No se pudieron cargar los paises.";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading countries: {ex.Message}";
        }
    }

    private async Task CreateCountry()
    {
        try
        {
            if (ApiClient != null)
            {
                var response = await ApiClient.PostAsync<CreateCountryRequest, ApiResponse<CountryDto>>(
                    "/api/countries", newCountry);

                if (response?.Success == true)
                {
                    newCountry = new();
                    showCreateForm = false;
                    successMessage = "Pais creado correctamente.";
                    errorMessage = string.Empty;
                    await LoadCountries();
                }
                else
                {
                    errorMessage = response?.Message ?? "No se pudo crear el pais.";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error creating country: {ex.Message}";
        }
    }

    private Task EditCountry(CountryDto country)
    {
        editingCountryId = country.Id;
        editCountryName = country.Name;
        successMessage = string.Empty;
        errorMessage = string.Empty;
        return Task.CompletedTask;
    }

    private async Task SaveCountryEdit()
    {
        try
        {
            if (ApiClient == null || editingCountryId == null)
                return;

            var request = new UpdateCountryRequest { Name = editCountryName };
            var response = await ApiClient.PutAsync<UpdateCountryRequest, ApiResponse<CountryDto>>(
                $"/api/countries/{editingCountryId.Value}", request);

            if (response?.Success == true)
            {
                successMessage = "Pais actualizado correctamente.";
                errorMessage = string.Empty;
                editingCountryId = null;
                await LoadCountries();
            }
            else
            {
                errorMessage = response?.Message ?? "No se pudo actualizar el pais.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating country: {ex.Message}";
        }
    }

    private Task CancelCountryEdit()
    {
        editingCountryId = null;
        editCountryName = string.Empty;
        return Task.CompletedTask;
    }

    private async Task DeleteCountry(int id)
    {
        try
        {
            if (ApiClient != null)
            {
                var response = await ApiClient.DeleteAsync<ApiResponse<string>>($"/api/countries/{id}");
                if (response?.Success == true)
                {
                    successMessage = "Pais eliminado correctamente.";
                    errorMessage = string.Empty;
                    await LoadCountries();
                }
                else
                {
                    errorMessage = response?.Message ?? "No se pudo eliminar el pais.";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting country: {ex.Message}";
        }
    }
}
